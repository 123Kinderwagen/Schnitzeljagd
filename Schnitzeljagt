<!DOCTYPE html>
<html>
<head>
<meta charset="UTF-8">
<title>Ping Pong Spiel</title>
</head>

<body style="text-align:center; font-family:Arial;">

<h1>🏓 Ping Pong Challenge</h1>
<p>Steuerung mit ↑ und ↓</p>

<canvas id="game" width="600" height="400" style="border:2px solid black;"></canvas>

<p id="score">Siege: 0 / 3</p>
<h2 id="result" style="color:green;"></h2>

<script>
let canvas = document.getElementById("game");
let ctx = canvas.getContext("2d");

let playerY = 160;
let enemyY = 160;

let ballX = 300;
let ballY = 200;
let speedX = 4;
let speedY = 3;

let wins = 0;
let gameOver = false;

let up = false;
let down = false;

document.addEventListener("keydown", (e) => {
    if (e.key === "ArrowUp") up = true;
    if (e.key === "ArrowDown") down = true;
});

document.addEventListener("keyup", (e) => {
    if (e.key === "ArrowUp") up = false;
    if (e.key === "ArrowDown") down = false;
});

function game() {

    if (gameOver) return;

    if (up) playerY -= 6;
    if (down) playerY += 6;

    playerY = Math.max(0, Math.min(320, playerY));

    enemyY += (playerY - enemyY) * 0.07;

    ballX += speedX;
    ballY += speedY;

    if (ballY <= 0 || ballY >= 390) speedY *= -1;

    if (ballX < 30 && ballY > playerY && ballY < playerY + 80) {
        speedX *= -1.1;
    }

    if (ballX > 570 && ballY > enemyY && ballY < enemyY + 80) {
        speedX *= -1.05;
    }

    if (ballX > 600) {
        wins++;
        document.getElementById("score").innerText = "Siege: " + wins + " / 3";

        if (wins >= 3) {
            gameOver = true;
            document.getElementById("result").innerText = "🎉 GEHT ZUM SPIELPLATZ 🎉";
        }

